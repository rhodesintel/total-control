package com.rhodesai.total_control

import android.app.Notification
import android.app.NotificationChannel
import android.app.NotificationManager
import android.app.PendingIntent
import android.accessibilityservice.AccessibilityServiceInfo
import android.content.Context
import android.content.Intent
import android.content.SharedPreferences
import android.net.VpnService
import android.view.accessibility.AccessibilityManager
import android.os.Build
import android.os.ParcelFileDescriptor
import android.util.Log
import androidx.core.app.NotificationCompat
import org.xbill.DNS.*
import java.io.FileInputStream
import java.io.FileOutputStream
import java.net.DatagramPacket
import java.net.DatagramSocket
import java.net.InetAddress
import java.nio.ByteBuffer
import kotlin.concurrent.thread

/**
 * Total Control VPN Service - DNS filtering using dnsjava
 *
 * Based on personalDNSfilter pattern:
 * 1. Read IP packets from TUN
 * 2. Parse IP/UDP headers, extract DNS payload
 * 3. Use dnsjava to parse DNS queries
 * 4. Forward allowed queries via protected socket
 * 5. Build response packets and write back to TUN
 */
class TotalControlVpnService : VpnService() {

    companion object {
        private const val TAG = "TotalControlVPN"
        private const val CHANNEL_ID = "total_control_vpn"
        private const val CHANNEL_ID_BLOCKS = "total_control_blocks"
        private const val NOTIFICATION_ID = 1
        private const val NOTIFICATION_ID_BLOCK = 2

        private const val VPN_ADDRESS = "10.0.0.2"
        private const val VPN_DNS = "10.0.0.1"
        private const val MTU = 1500

        private const val PREFS_NAME = "FlutterSharedPreferences"
        private const val KEY_BLOCKED_SITES = "flutter.blocked_sites"
        private const val KEY_SYLLABUS_FILMS = "flutter.syllabus_films"

        @Volatile
        var isRunning = false
            private set
    }

    private var lastBlockNotification = 0L
    private var blockCount = 0

    private var vpnInterface: ParcelFileDescriptor? = null
    private lateinit var prefs: SharedPreferences
    @Volatile
    private var running = false

    override fun onCreate() {
        super.onCreate()
        prefs = getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE)
        createNotificationChannel()
        Log.i(TAG, "VPN Service created (dnsjava)")
    }

    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        if (intent?.action == "STOP") {
            stopVpn()
            return START_NOT_STICKY
        }

        startForeground(NOTIFICATION_ID, createNotification())
        startVpn()
        return START_STICKY
    }

    override fun onDestroy() {
        stopVpn()
        super.onDestroy()
    }

    private fun startVpn() {
        if (isRunning) {
            Log.d(TAG, "VPN already running")
            return
        }

        try {
            val builder = Builder()
                .setSession("Total Control")
                .addAddress(VPN_ADDRESS, 24)
                .addDnsServer(VPN_DNS)
                .setMtu(MTU)
                .setBlocking(true)

            // Route only our fake DNS through VPN
            builder.addRoute(VPN_DNS, 32)
            builder.addDisallowedApplication(packageName)

            vpnInterface = builder.establish()

            if (vpnInterface == null) {
                Log.e(TAG, "Failed to establish VPN interface")
                stopSelf()
                return
            }

            Log.i(TAG, "VPN interface established")
            isRunning = true
            running = true

            // Start packet processing thread
            thread(name = "VPN-DNS-Handler") {
                processPackets()
            }

        } catch (e: Exception) {
            Log.e(TAG, "Error starting VPN: ${e.message}", e)
            stopVpn()
        }
    }

    private fun processPackets() {
        val vpn = vpnInterface ?: return
        val input = FileInputStream(vpn.fileDescriptor)
        val output = FileOutputStream(vpn.fileDescriptor)
        val buffer = ByteArray(MTU)

        Log.i(TAG, "Packet processing started")

        while (running) {
            try {
                val length = input.read(buffer)
                if (length <= 0) continue

                // Parse IP header
                val version = (buffer[0].toInt() and 0xF0) shr 4
                if (version != 4) continue  // IPv4 only for now

                val ihl = (buffer[0].toInt() and 0x0F) * 4
                val protocol = buffer[9].toInt() and 0xFF

                // Only handle UDP (protocol 17)
                if (protocol != 17) continue

                // Parse UDP header (starts at ihl)
                val srcPort = ((buffer[ihl].toInt() and 0xFF) shl 8) or (buffer[ihl + 1].toInt() and 0xFF)
                val dstPort = ((buffer[ihl + 2].toInt() and 0xFF) shl 8) or (buffer[ihl + 3].toInt() and 0xFF)

                // Only handle DNS (port 53)
                if (dstPort != 53) continue

                // Extract DNS payload
                val dnsStart = ihl + 8
                val dnsPayload = buffer.copyOfRange(dnsStart, length)

                // Handle DNS query in separate thread to not block
                thread {
                    try {
                        handleDnsQuery(buffer.copyOf(length), dnsPayload, output)
                    } catch (e: Exception) {
                        Log.e(TAG, "Error handling DNS query: ${e.message}")
                    }
                }

            } catch (e: Exception) {
                if (running) {
                    Log.e(TAG, "Packet read error: ${e.message}")
                }
            }
        }

        Log.i(TAG, "Packet processing stopped")
    }

    private fun handleDnsQuery(originalPacket: ByteArray, dnsPayload: ByteArray, output: FileOutputStream) {
        try {
            // Parse DNS query using dnsjava
            val query = Message(dnsPayload)
            val question = query.question ?: return
            val queryName = question.name.toString().trimEnd('.')

            Log.d(TAG, "DNS query: $queryName")

            // Check if should block
            if (shouldBlock(queryName)) {
                Log.i(TAG, "BLOCKED: $queryName")
                showBlockNotification(queryName)
                val nxResponse = buildNxdomainResponse(query)
                val responsePacket = buildResponsePacket(originalPacket, nxResponse)
                synchronized(output) {
                    output.write(responsePacket)
                }
                return
            }

            // Forward to real DNS
            val response = forwardDnsQuery(dnsPayload)
            if (response != null) {
                val responsePacket = buildResponsePacket(originalPacket, response)
                synchronized(output) {
                    output.write(responsePacket)
                }
            }

        } catch (e: Exception) {
            Log.e(TAG, "DNS handling error: ${e.message}")
        }
    }

    private fun shouldBlock(domain: String): Boolean {
        val blockedSites = getBlockedSites()
        val syllabusFilms = getSyllabusFilms()
        val lowerDomain = domain.lowercase()

        for (blocked in blockedSites) {
            if (lowerDomain.contains(blocked.lowercase())) {
                // If syllabus is empty, block everything
                // If syllabus has items, we allow (AccessibilityService handles fine-grained control)
                if (syllabusFilms.isEmpty()) {
                    return true
                }
            }
        }
        return false
    }

    private fun forwardDnsQuery(dnsPayload: ByteArray): ByteArray? {
        var socket: DatagramSocket? = null
        try {
            socket = DatagramSocket()

            // CRITICAL: Protect socket from VPN routing loop
            if (!protect(socket)) {
                Log.e(TAG, "Failed to protect socket")
                return null
            }

            val dnsServer = InetAddress.getByName("8.8.8.8")
            val requestPacket = DatagramPacket(dnsPayload, dnsPayload.size, dnsServer, 53)

            socket.soTimeout = 5000  // 5 second timeout
            socket.send(requestPacket)

            val responseBuffer = ByteArray(512)
            val responsePacket = DatagramPacket(responseBuffer, responseBuffer.size)
            socket.receive(responsePacket)

            return responseBuffer.copyOf(responsePacket.length)

        } catch (e: Exception) {
            Log.e(TAG, "DNS forward error: ${e.message}")
            return null
        } finally {
            socket?.close()
        }
    }

    private fun buildNxdomainResponse(query: Message): ByteArray {
        val response = Message(query.header.id)
        response.header.setFlag(Flags.QR.toInt())  // This is a response
        response.header.setFlag(Flags.RA.toInt())  // Recursion available
        response.header.rcode = Rcode.NXDOMAIN

        // Copy question section
        query.question?.let { response.addRecord(it, Section.QUESTION) }

        return response.toWire()
    }

    private fun buildResponsePacket(originalPacket: ByteArray, dnsResponse: ByteArray): ByteArray {
        val ihl = (originalPacket[0].toInt() and 0x0F) * 4

        // Extract original addresses and ports
        val srcIp = originalPacket.copyOfRange(12, 16)
        val dstIp = originalPacket.copyOfRange(16, 20)
        val srcPort = originalPacket.copyOfRange(ihl, ihl + 2)
        val dstPort = originalPacket.copyOfRange(ihl + 2, ihl + 4)

        // Build response packet: IP header + UDP header + DNS response
        val udpLength = 8 + dnsResponse.size
        val totalLength = ihl + udpLength

        val response = ByteArray(totalLength)

        // Copy and modify IP header
        System.arraycopy(originalPacket, 0, response, 0, ihl)

        // Swap source and destination IP
        System.arraycopy(dstIp, 0, response, 12, 4)
        System.arraycopy(srcIp, 0, response, 16, 4)

        // Set total length
        response[2] = ((totalLength shr 8) and 0xFF).toByte()
        response[3] = (totalLength and 0xFF).toByte()

        // Clear IP checksum (will recalculate)
        response[10] = 0
        response[11] = 0

        // Calculate IP checksum
        val ipChecksum = calculateChecksum(response, 0, ihl)
        response[10] = ((ipChecksum shr 8) and 0xFF).toByte()
        response[11] = (ipChecksum and 0xFF).toByte()

        // Build UDP header (swap ports)
        System.arraycopy(dstPort, 0, response, ihl, 2)      // Source port (was dest)
        System.arraycopy(srcPort, 0, response, ihl + 2, 2)  // Dest port (was source)
        response[ihl + 4] = ((udpLength shr 8) and 0xFF).toByte()
        response[ihl + 5] = (udpLength and 0xFF).toByte()
        response[ihl + 6] = 0  // UDP checksum (optional for IPv4)
        response[ihl + 7] = 0

        // Copy DNS response
        System.arraycopy(dnsResponse, 0, response, ihl + 8, dnsResponse.size)

        return response
    }

    private fun calculateChecksum(data: ByteArray, offset: Int, length: Int): Int {
        var sum = 0
        var i = offset
        while (i < offset + length - 1) {
            sum += ((data[i].toInt() and 0xFF) shl 8) or (data[i + 1].toInt() and 0xFF)
            i += 2
        }
        if (length % 2 == 1) {
            sum += (data[offset + length - 1].toInt() and 0xFF) shl 8
        }
        while (sum shr 16 != 0) {
            sum = (sum and 0xFFFF) + (sum shr 16)
        }
        return sum.inv() and 0xFFFF
    }

    private fun stopVpn() {
        Log.i(TAG, "Stopping VPN...")
        running = false

        try {
            vpnInterface?.close()
        } catch (e: Exception) {
            Log.e(TAG, "Error closing VPN interface: ${e.message}")
        }
        vpnInterface = null

        isRunning = false
        stopForeground(STOP_FOREGROUND_REMOVE)
        stopSelf()
        Log.i(TAG, "VPN stopped")
    }

    private fun getBlockedSites(): Set<String> {
        val sites = prefs.getStringSet(KEY_BLOCKED_SITES, null)
        if (sites != null) return sites

        // Block VIDEO CDN domains (allows search/browse, blocks actual video streams)
        // Plus full site blocks for services without useful browse features
        return setOf(
            // YouTube video CDN (allows youtube.com search/browse)
            "googlevideo.com",
            "ytimg.com",

            // Netflix video CDN (allows netflix.com browse)
            "nflxvideo.net",

            // Full site blocks (no useful browse, just consumption)
            "twitch.tv",
            "tiktok.com",

            // Other streaming (block entirely - mostly app-based)
            "primevideo.com",
            "disneyplus.com",
            "hulu.com",
            "max.com",
            "hbomax.com",
            "crunchyroll.com",
            "peacocktv.com",
            "paramountplus.com",
        )
    }

    private fun getSyllabusFilms(): Set<String> {
        return prefs.getStringSet(KEY_SYLLABUS_FILMS, null) ?: emptySet()
    }

    private fun showBlockNotification(domain: String) {
        val now = System.currentTimeMillis()
        blockCount++

        // Throttle notifications - max once per 2 seconds
        if (now - lastBlockNotification < 2000) return
        lastBlockNotification = now

        // Extract readable site name (e.g., "youtube.com" from "www.youtube.com")
        val siteName = domain.replace("www.", "").split(".").take(2).joinToString(".")

        val notification = NotificationCompat.Builder(this, CHANNEL_ID_BLOCKS)
            .setContentTitle("Blocked: $siteName")
            .setContentText("Total Control prevented access. Add to syllabus to allow.")
            .setSmallIcon(android.R.drawable.ic_delete)
            .setAutoCancel(true)
            .setPriority(NotificationCompat.PRIORITY_HIGH)
            .build()

        getSystemService(NotificationManager::class.java)
            .notify(NOTIFICATION_ID_BLOCK, notification)
    }

    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val manager = getSystemService(NotificationManager::class.java)

            // VPN status channel (low priority, ongoing)
            val vpnChannel = NotificationChannel(
                CHANNEL_ID,
                "Total Control VPN",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "DNS filtering active"
                setShowBadge(false)
            }
            manager.createNotificationChannel(vpnChannel)

            // Block alerts channel (high priority, visible)
            val blockChannel = NotificationChannel(
                CHANNEL_ID_BLOCKS,
                "Block Alerts",
                NotificationManager.IMPORTANCE_HIGH
            ).apply {
                description = "Notifications when sites are blocked"
                setShowBadge(true)
            }
            manager.createNotificationChannel(blockChannel)
        }
    }

    private fun createNotification(): Notification {
        val stopIntent = Intent(this, TotalControlVpnService::class.java).apply {
            action = "STOP"
        }
        val stopPendingIntent = PendingIntent.getService(
            this, 0, stopIntent,
            PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
        )

        val openIntent = packageManager.getLaunchIntentForPackage(packageName)
        val openPendingIntent = PendingIntent.getActivity(
            this, 0, openIntent,
            PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
        )

        return NotificationCompat.Builder(this, CHANNEL_ID)
            .setContentTitle("Total Control Active")
            .setContentText("DNS filtering enabled")
            .setSmallIcon(android.R.drawable.ic_lock_lock)
            .setOngoing(true)
            .setContentIntent(openPendingIntent)
            .addAction(android.R.drawable.ic_menu_close_clear_cancel, "Stop", stopPendingIntent)
            .build()
    }
}
